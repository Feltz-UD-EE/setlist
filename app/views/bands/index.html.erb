<p style="color: green"><%= notice %></p>

<% content_for :title, "Bands" %>

<h1>Bands</h1>

<div id="bands">
  <% @bands.each do |band| %>
    <%= render band %>
    <p>
      <%= link_to "Show this band", band %>
    </p>
  <% end %>
</div>

<%# Band creation is disabled during closed beta.
    Restore this link when public band signup is ready:
    link_to "New band", new_band_path %>
