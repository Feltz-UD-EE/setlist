<div>
  <h1>Setlist</h1>
  <p class="landing-copy">A private workspace for bands to manage songs, set lists, performance notes, and practice-ready pages.</p>

  <% if signed_out? %>
    <p class="action-row">
      <%= link_to "Log in", sign_in_path, class: "button button--play" %>
      <%= link_to "Create an account", sign_up_path, class: "button" %>
    </p>
  <% else %>
    <h2>Your Bands</h2>
    <div class="link-list">
    <% @bands.each do |band| %>
      <p><%= link_to band.name, band_path(band) %></p>
    <% end %>
    </div>
  <% end %>
</div>
