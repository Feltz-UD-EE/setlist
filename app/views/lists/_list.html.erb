<div id="<%= dom_id list %>">
  <h1><%= @list.band.name %>: <%= @list.name %></h1>
  <% if @list.notes.present? %>
    <p class="setlist-notes"><%= @list.notes %></p>
  <% end %>
  <div class="setlist-summary">
    <p><strong>Songs:</strong> <%= @songs.length %></p>
    <p><strong>Total run time:</strong> <%= @list.runtime_pretty %></p>
  </div>
  <div class="setlist-summary setlist-summary--dates">
    <p><strong>Created:</strong> <%= @list.created_at.strftime("%b %-d, %Y") %></p>
    <p><strong>Updated:</strong> <%= @list.updated_at.strftime("%b %-d, %Y") %></p>
  </div>
  <h2>Songs</h2>
  <table>
    <thead>
    <tr>
      <th>Title</th>
      <th>Performer</th>
      <th>Duration</th>
      <th>Intro</th>
      <th>Finish</th>
    </tr>
    </thead>
    <tbody>
    <% @songs.each do |song| %>
      <tr>
        <td><%= link_to song.title, song_path(song) %></td>
        <td><%= song.performer %></td>
        <td><%= song.duration_pretty %></td>
        <td><span class="song-note song-note--intro song-note--inline"><%= song.intro %></span></td>
        <td><span class="song-note song-note--finish song-note--inline"><%= song.finish %></span></td>
      </tr>
    <% end %>
    </tbody>
  </table>
</div>
