<p style="color: green"><%= notice %></p>

<% content_for :title, "Playing " + [@list.name, @song.title].join(" ") %>
<% if @sequence == 0 %>
  <p class="action-row"><%= link_to "Back", play_play_path(list_id: @list.id, instrument_ids: @instrument_ids), class: "button" %></p>
<% else %>
  <p class="action-row"><%= link_to "Back", play_play_song_path(list_id: @list.id, instrument_ids: @instrument_ids, song_sequence: @sequence-1), class: "button" %></p>
<% end %>

<h1><%= @song.title %></h1>
<% @preps.each do |prep| %>
  <p class="song-note song-note--prep"><strong><%= prep.instrument.name %>:</strong> <%= prep.instruction %></p>
<% end %>
<p class="song-note song-note--intro"><strong>Intro:</strong> <%= @song.intro %></p>

<% if @sheets.any? %>
  <div class="song-sheets">
    <% @sheets.each do |sheet| %>
      <% if sheet.alternate? %>
        <p class="alternate-image-label"><span class="alternate-image-icon" title="Alternate instrument sheet">ALT</span> Alternate sheet for <%= sheet.instrument_names %></p>
      <% end %>
      <%= image_tag sheet.img.url, class: "song-sheet-image" %>
    <% end %>
  </div>
<% else %>
  <p class="song-media-placeholder">No sheets uploaded</p>
<% end %>

<p class="song-note song-note--finish"><strong>Finish:</strong> <%= @song.finish %></p>
<% if @next_song.present? %>
  <section class="next-song">
  <h2>Next: <%= @next_song.title %></h2>
  <% @next_preps.each do |prep| %>
    <p class="song-note song-note--prep"><strong><%= prep.instrument.name %>:</strong> <%= prep.instruction %></p>
  <% end %>
  <p class="song-note song-note--intro"><strong>Intro:</strong> <%= @next_song.intro %></p>
  </section>
<% else %>
  <h2>End of Set List</h2>
  <p class="action-row"><%= link_to "All Set Lists", band_path(@list.band), class: "button button--play" %></p>
<% end %>

<% if @next_song.present? %>
  <p class="action-row"><%= link_to "Next", play_play_song_path(list_id: @list.id, instrument_ids: @instrument_ids, song_sequence: @sequence+1), class: "button button--play" %></p>
<% end %>
