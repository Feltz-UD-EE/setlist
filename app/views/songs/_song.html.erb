<div id="<%= dom_id song %>">
  <h1><%= @song.band.name %>: <%= @song.title %></h1>
  <dl class="song-detail-list">
    <div>
      <dt>Duration</dt>
      <dd><%= @song.duration_pretty %></dd>
    </div>
    <div>
      <dt>Performer</dt>
      <dd><%= @song.performer %></dd>
    </div>
    <div>
      <dt>Version</dt>
      <dd><%= @song.version %></dd>
    </div>
  </dl>
  <p class="song-note song-note--intro"><strong>Intro:</strong> <span><%= @song.intro %></span></p>
  <p class="song-note song-note--finish"><strong>Finish:</strong> <span><%= @song.finish %></span></p>
  <h2>Set Lists</h2>
  <% @song.lists.each do |list| %>
    <p><%= link_to list.name, list_path(list) %></p>
  <% end %>
  <h2>Preparations</h2>
  <table>
    <thead>
    <tr>
      <th>Instrument</th>
      <th>Instruction</th>
    </tr>
    </thead>
    <tbody>
    <% @preparations.each do |prep| %>
      <tr>
        <td><%= prep.instrument.name %></td>
        <td><span class="song-note song-note--prep song-note--inline"><%= prep.instruction %></span></td>
      </tr>
    <% end %>
    </tbody>
  </table>
  <h2>Pages</h2>
  <p>Preview goes here - need to figure out stuff with image processing gems</p>
  <table>
    <thead>
    <tr>
      <th>Order</th>
      <th>Preview</th>
      <th>Instrument</th>
    </tr>
    </thead>
    <tbody>
    <% @pages.each do |page| %>
      <tr>
        <td><%= page.sort_order %></td>
        <td><%= image_tag page.img.url, class: "song-page-thumb" %></td>
        <td><%= page.instrument.present? ? page.instrument.name : "" %></td>
      </tr>
    <% end %>
    </tbody>
  </table>
  <p><%= link_to "Add a page", new_page_path(:song_id => @song.id) %></p>
</div>
