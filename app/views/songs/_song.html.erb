<div id="<%= dom_id song %>">
  <h1>
    <%= @song.band.name %>: <%= @song.title %>
    <% if @song.alternate_sheets? %>
      <span class="alternate-image-icon" title="Alternate instrument sheets">ALT</span>
    <% end %>
  </h1>
  <dl class="song-detail-list">
    <div>
      <dt>Duration</dt>
      <dd><%= @song.duration_pretty %></dd>
    </div>
    <div>
      <dt>Performer</dt>
      <dd><%= @song.performer %></dd>
    </div>
    <div>
      <dt>Version</dt>
      <dd><%= @song.version %></dd>
    </div>
  </dl>
  <p class="song-note song-note--intro"><strong>Intro:</strong> <span><%= @song.intro %></span></p>
  <p class="song-note song-note--finish"><strong>Finish:</strong> <span><%= @song.finish %></span></p>
  <h2>Set Lists</h2>
  <% @song.lists.each do |list| %>
    <p><%= link_to list.name, list_path(list) %></p>
  <% end %>
  <h2>Preparations</h2>
  <table>
    <thead>
    <tr>
      <th>Instrument</th>
      <th>Instruction</th>
    </tr>
    </thead>
    <tbody>
    <% @preparations.each do |prep| %>
      <tr>
        <td><%= prep.instrument.name %></td>
        <td><span class="song-note song-note--prep song-note--inline"><%= prep.instruction %></span></td>
      </tr>
    <% end %>
    </tbody>
  </table>
  <h2>Sheets</h2>
  <div class="song-sheet-groups">
    <% if @main_sheets.any? %>
      <section class="song-sheet-group">
        <h3>Main sheets</h3>
        <div class="song-sheet-row">
          <% @main_sheets.each do |sheet| %>
            <%= image_tag sheet.img.url, class: "song-sheet-thumb" %>
          <% end %>
        </div>
      </section>
    <% end %>

    <% @alternate_sheet_groups.each do |instrument, sheets| %>
      <section class="song-sheet-group">
        <h3><%= instrument.name %></h3>
        <div class="song-sheet-row">
          <% sheets.each do |sheet| %>
            <%= image_tag sheet.img.url, class: "song-sheet-thumb" %>
          <% end %>
        </div>
      </section>
    <% end %>
  </div>
</div>
