<%= form_with(model: song) do |form| %>
  <% if song.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(song.errors.count, "error") %> prohibited this song from being saved:</h2>

      <ul>
        <% song.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <table>
      <% if @song.band_id.present? %>
        <%= form.hidden_field :band_id, value: @song.band_id %>
    <% else %>
        <tr>
          <td>Band</td>
          <td><%= form.collection_select :band_id, @song_form_bands, :id, :name, { include_blank: "-- Please select a band --" } %></td>
        </tr>
      <% end %>
      <tr>
        <td>Title</td>
        <td><%= form.text_field :title %></td>
      </tr>
      <tr>
        <td>Performer</td>
        <td><%= form.text_field :performer %></td>
      </tr>
      <tr>
        <td>Version</td>
        <td><%= form.text_field :version %></td>
      </tr>
      <tr>
        <td>Intro</td>
        <td><%= form.text_field :intro %></td>
      </tr>
      <tr>
        <td>Duration (seconds)</td>
        <td><%= form.text_field :duration %></td>
      </tr>
      <tr>
        <td>Finish</td>
        <td><%= form.text_field :finish %></td>
      </tr>
    </table>

    <section class="preparation-editor" data-controller="preparation-editor">
      <div class="preparation-editor__header">
        <h2>Preparations</h2>
        <button type="button" class="button button--small" data-action="preparation-editor#add">Add more</button>
      </div>

      <div class="preparation-editor__rows" data-preparation-editor-target="list">
        <% @preparations_for_form.each do |preparation| %>
          <div class="preparation-row" data-preparation-row data-persisted="true">
            <%= hidden_field_tag "preparations[#{preparation.id}][id]", preparation.id %>
            <%= hidden_field_tag "preparations[#{preparation.id}][_destroy]", "0", data: { preparation_destroy_input: true } %>

            <label>
              Instrument
              <%= select_tag "preparations[#{preparation.id}][instrument_id]", options_from_collection_for_select(@instruments, :id, :name, preparation.instrument_id), prompt: "Choose an instrument" %>
            </label>

            <label>
              Instructions
              <%= text_field_tag "preparations[#{preparation.id}][instruction]", preparation.instruction %>
            </label>

            <button type="button" class="preparation-remove-button" aria-label="Remove preparation" data-action="preparation-editor#remove">X</button>
          </div>
        <% end %>
      </div>

      <div hidden data-preparation-editor-target="destroyList"></div>

      <template data-preparation-editor-target="template">
        <div class="preparation-row" data-preparation-row>
          <%= hidden_field_tag "preparations[NEW_PREPARATION][_destroy]", "0", data: { preparation_destroy_input: true } %>

          <label>
            Instrument
            <%= select_tag "preparations[NEW_PREPARATION][instrument_id]", options_from_collection_for_select(@instruments, :id, :name), prompt: "Choose an instrument" %>
          </label>

          <label>
            Instructions
            <%= text_field_tag "preparations[NEW_PREPARATION][instruction]", nil %>
          </label>

          <button type="button" class="preparation-remove-button" aria-label="Remove preparation" data-action="preparation-editor#remove">X</button>
        </div>
      </template>
    </section>

    <section class="sheet-editor" data-controller="sheet-editor">
      <div class="sheet-editor__header">
        <h2>Sheets</h2>
        <div class="sheet-editor__actions">
          <button type="button" class="button button--small" data-action="sheet-editor#chooseMainSheet">Upload main sheet</button>
          <button type="button" class="button button--small" data-action="sheet-editor#openAlternateDialog">Upload alternate sheet</button>
        </div>
      </div>

      <%= form.file_field :sheet_imgs, accept: "image/*", multiple: true, class: "visually-hidden", data: { sheet_editor_target: "mainInput", action: "change->sheet-editor#mainSheetSelected" } %>

      <dialog class="confirm-dialog" data-sheet-editor-target="dialog">
        <div class="confirm-dialog__content">
          <h2>Alternate sheet</h2>
          <label class="sheet-editor__dialog-field">
            Instrument
            <%= form.collection_select :alternate_sheet_instrument_ids, @instruments, :id, :name, { prompt: "Choose an instrument" }, class: "compact-select" %>
          </label>
          <div class="confirm-dialog__actions">
            <button type="button" class="button" data-action="sheet-editor#closeAlternateDialog">Cancel</button>
            <button type="button" class="button button--primary" data-action="sheet-editor#chooseAlternateSheet">Choose file</button>
          </div>
        </div>
      </dialog>
      <%= form.file_field :alternate_sheet_imgs, accept: "image/*", multiple: true, class: "visually-hidden", data: { sheet_editor_target: "alternateInput", action: "change->sheet-editor#alternateSheetSelected" } %>

      <div class="sheet-lane sheet-lane--main">
        <h3>Main sheets</h3>
        <div class="sheet-lane__items" data-sheet-editor-target="lane mainPreview" data-sheet-lane="main">
          <% @main_sheets.each do |sheet| %>
            <%= render "songs/sheet_card", sheet: sheet, lane: "main" %>
          <% end %>
        </div>
      </div>

      <% @alternate_sheet_groups.each do |instrument, sheets| %>
        <div class="sheet-lane">
          <h3><%= instrument.name %></h3>
          <div class="sheet-lane__items" data-sheet-editor-target="lane" data-sheet-lane="instrument-<%= instrument.id %>">
            <% sheets.each do |sheet| %>
              <%= render "songs/sheet_card", sheet: sheet, lane: "instrument-#{instrument.id}" %>
            <% end %>
          </div>
        </div>
      <% end %>

      <div class="sheet-lane sheet-lane--pending-alternate" data-sheet-editor-target="alternateLane" hidden>
        <h3 data-sheet-editor-target="alternateHeading">Alternate Sheets</h3>
        <div class="sheet-lane__items" data-sheet-editor-target="lane alternatePreview" data-sheet-lane="pending-alternate-new"></div>
      </div>
    </section>

    <%= form.submit song.persisted? ? "Save Song" : nil %>
  </div>
<% end %>
