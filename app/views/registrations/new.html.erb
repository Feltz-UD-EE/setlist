<% content_for :title, "Create an account" %>

<h1>Create an account</h1>

<% if @invitation.present? %>
  <p class="meta-line">Joining <%= @invitation.band.name %></p>
<% else %>
  <p>A band invitation link is required to create an account.</p>
<% end %>

<%= form_with model: @player, url: users_path(invite: @invite_token), class: "play-setup-form" do |form| %>
  <% if @player.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(@player.errors.count, "error") %> prohibited this account from being created:</h2>
      <ul>
        <% @player.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <p class="form-field">
    <strong>First name</strong>
    <%= form.text_field :first_name %>
  </p>
  <p class="form-field">
    <strong>Last name</strong>
    <%= form.text_field :last_name %>
  </p>
  <p class="form-field">
    <strong>Email</strong>
    <%= form.email_field :email %>
  </p>
  <p class="form-field">
    <strong>Password</strong>
    <%= form.password_field :password %>
  </p>

  <p class="action-row"><%= form.submit "Create account", class: "button button--play" %></p>
<% end %>
